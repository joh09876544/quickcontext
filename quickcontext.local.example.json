{
  "qdrant": {
    "host": "localhost",
    "port": 6333,
    "grpc_port": 6334,
    "prefer_grpc": true,
    "collection": "codebase",
    "timeout": 30.0
  },
  "code_embedding": {
    "provider": "fastembed",
    "model": "jinaai/jina-embeddings-v2-base-code",
    "dimension": 768,
    "batch_size": 32
  },
  "desc_embedding": {
    "provider": "fastembed",
    "model": "BAAI/bge-small-en-v1.5",
    "dimension": 384,
    "batch_size": 32
  },
  "llm": null,
  "vectors": [
    {
      "name": "code",
      "dimension": 768,
      "distance": "cosine"
    },
    {
      "name": "description",
      "dimension": 384,
      "distance": "cosine"
    }
  ]
}
